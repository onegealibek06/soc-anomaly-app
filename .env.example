# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key_here"

# ── API & Auth secrets ─────────────────────────────────────────────────────────
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY="your_api_key_here"
JWT_SECRET="your_jwt_secret_here"
ADMIN_EMAIL="admin@yourdomain.com"

# ── Telegram alerts (critical/high incidents) ──────────────────────────────────
# Get token: https://t.me/BotFather → /newbot
# Get chat_id: message your bot, then open:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_CHAT_ID="your_chat_id_here"

# ── Optional: generic webhook (Slack, Discord, n8n, etc.) ─────────────────────
ALERT_WEBHOOK_URL=""
